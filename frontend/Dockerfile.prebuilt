# 用 Mac/CI 预先构建好的 dist/ 直接打 nginx 镜像。
# 不在服务器跑 npm（绕开 npm 网络/内存问题）。
#
# 前提：在 build 之前，先在 Mac 上 `cd frontend && npm run build` 得到 dist/。
# 然后 docker build 时 dist/ 会被 COPY 进镜像。

FROM nginx:alpine
COPY dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
