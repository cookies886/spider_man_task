# ============================================================
# SpiderMan 远程 Worker 配置
# ============================================================
# 操作步骤：
#   1. 登录主控 Web UI（管理员），在 Worker 节点页面点「+ 添加节点」
#   2. 填好 name/hostname/IP，保存后会一次性显示一个 API Key
#   3. 把那个 API Key、你填的 node_id、主控的 ws:// 地址填到下面
#   4. cp .env.example .env && ./install.sh
# ============================================================

# 主控的 WebSocket 地址（注意是 ws:// 不是 http://）
MASTER_URL=ws://主控IP:8000

# 在主控 UI 添加节点时一次性显示的 API Key（明文，关闭对话框后无法再看）
API_KEY=填入主控显示的-api-key

# 主控 UI 添加节点时填的 node_id
NODE_ID=填入-node-id

# 节点显示名（任意）
NODE_NAME=remote-prod-1

# 工作目录（host 路径，存项目文件 / 任务执行 cwd）
DATA_ROOT=/opt/spiderman-worker

# 镜像版本
VERSION=1.0

# 心跳间隔（秒）
HEARTBEAT_INTERVAL=5

# 监听端口（一般不用改）
LISTEN_PORT=8001
