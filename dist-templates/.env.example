# ============================================================
# SpiderMan 部署配置
# ============================================================
# 复制为 .env 后再 ./install.sh，或者直接让 install.sh 帮你生成。
# 标 ⚠ 的项生产环境强烈建议改。

# ---------- 端口 ----------

# Web 前端端口（浏览器访问）
FRONTEND_PORT=3000

# 后端 API 端口
BACKEND_PORT=8000

# ---------- 数据持久化 ----------

# 所有数据落盘目录（pgdata / redisdata / projects / zips / logs / persistent / workerdata）
DATA_ROOT=/opt/spiderman

# ---------- 安全 ----------

# ⚠ JWT 签名 + Fernet 派生密钥。任何长随机串。
# ⚠ 一旦设定不要再改 — 改后旧加密数据（环境变量、git 凭据）无法解密。
SECRET_KEY=please-change-me-to-a-long-random-string

# ⚠ 默认管理员账号密码。首次登录后请立即在 UI 里改。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ⚠ master_local 内置 worker 反向连入主控用的 bearer key。任何长随机串。
MASTER_LOCAL_API_KEY=please-change-me-to-a-random-string
MASTER_LOCAL_NODE_ID=master-local

# ⚠ Postgres 密码（compose 内部网络可见，但建议改）
DB_PASSWORD=spiderman

# ---------- 性能 ----------

# uvicorn worker 进程数
WORKERS=2

# ---------- 镜像版本（升级时改）----------

VERSION=1.0
